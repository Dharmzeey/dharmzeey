---
import Layout from "../../layouts/Layout.astro";
import { getAllPosts } from "../../lib/contentful.js";

const posts = await getAllPosts();

function stripHtml(html: string) {
  return html.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").trim();
}

const [featured, ...rest] = posts;

const blogStructuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Adam Olanrewaju (Dharmzeey) Blog",
  url: "https://dharmzeey.com/blogs",
  description: "Articles on web development, Django, Next.js, Python, and software engineering by Adam Adedamola Olanrewaju (Dharmzeey).",
  author: {
    "@type": "Person",
    name: "Adam Adedamola Olanrewaju",
    alternateName: ["Dharmzeey", "Adam Olanrewaju"],
    url: "https://dharmzeey.com",
  },
  blogPost: posts.slice(0, 10).map((p) => ({
    "@type": "BlogPosting",
    headline: p.title,
    url: `https://dharmzeey.com/blogs/${p.slug}`,
    datePublished: p.date,
    author: {
      "@type": "Person",
      name: "Adam Adedamola Olanrewaju",
      alternateName: "Dharmzeey",
    },
  })),
};
---

<Layout
  title="Adam Olanrewaju (Dharmzeey) Blog - Web Development, Django, Next.js Articles"
  description="Read articles and insights from Adam Olanrewaju (Dharmzeey), a Full Stack Developer from Nigeria. Topics include Django, Next.js, Python, React, web development tutorials, and software engineering."
  keywords="Adam Olanrewaju blog, Dharmzeey blog, web development articles, Django tutorials, Next.js tutorials, Python programming, React tutorials, software development blog, tech insights, programming how-to guides, full stack developer blog, Nigeria tech blog, coding best practices"
  canonicalURL="https://dharmzeey.com/blogs"
  structuredData={blogStructuredData}
>
  <body class="text-white relative overflow-hidden">
    <main class="min-h-screen max-w-5xl mx-auto px-6 py-14">

      <!-- Top nav -->
      <div class="flex items-center justify-between mb-14">
        <a
          href="/"
          class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Portfolio
        </a>
        <span class="text-xs text-gray-600 uppercase tracking-widest">Blog</span>
      </div>

      <!-- Hero -->
      <div class="mb-14 max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
          Writing &amp; Insights
        </h1>
        <p class="text-gray-400 text-lg leading-relaxed">
          Thoughts on web development, engineering decisions, and the things I learn building real products.
        </p>
      </div>

      <!-- Featured post -->
      {featured && (
        <a
          href={`/blogs/${featured.slug}`}
          class="group block mb-14 rounded-2xl border border-white/10 bg-white/5 hover:border-white/25 hover:bg-white/[0.07] transition-all duration-300 overflow-hidden"
        >
          <div class="md:flex">
            {featured.image && (
              <div class="md:w-2/5 shrink-0">
                <img
                  src={featured.image}
                  alt={featured.title?.toString()}
                  class="w-full h-56 md:h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
                />
              </div>
            )}
            <div class="p-7 md:p-10 flex flex-col justify-center">
              <span class="text-xs text-blue-400 uppercase tracking-widest font-medium mb-3">Featured</span>
              <h2 class="text-2xl md:text-3xl font-bold mb-3 text-white group-hover:text-blue-400 transition-colors duration-300 leading-snug">
                {featured.title}
              </h2>
              <p class="text-gray-400 text-sm mb-1">
                {featured.author}
                {featured.date && (
                  <span> · {new Date(String(featured.date)).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
                )}
              </p>
              <p class="text-gray-300 text-sm leading-relaxed mt-3 line-clamp-3">
                {stripHtml(featured.content).slice(0, 180)}...
              </p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-blue-400 text-sm font-medium group-hover:gap-3 transition-all duration-200">
                Read article
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      )}

      <!-- All other posts -->
      {rest.length > 0 && (
        <section>
          <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-6">All Posts</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {rest.map((post) => (
              <a
                href={`/blogs/${post.slug}`}
                class="group flex flex-col bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-white/25 hover:bg-white/[0.07] hover:scale-[1.02] transition-all duration-300 shadow-md"
              >
                {post.image && (
                  <img
                    src={post.image}
                    alt={post.title?.toString()}
                    class="w-full h-44 object-cover group-hover:opacity-90 transition-opacity duration-300"
                  />
                )}
                <div class="p-5 flex flex-col flex-1">
                  <h3 class="text-base font-semibold mb-2 text-gray-100 group-hover:text-blue-400 transition-colors duration-300 leading-snug line-clamp-2">
                    {post.title}
                  </h3>
                  <p class="text-xs text-gray-500 mb-3">
                    {post.author}
                    {post.date && (
                      <span> · {new Date(String(post.date)).toLocaleDateString("en-US", { month: "short", year: "numeric" })}</span>
                    )}
                  </p>
                  <p class="text-gray-400 text-sm line-clamp-3 flex-1">
                    {stripHtml(post.content).slice(0, 110)}...
                  </p>
                  <span class="mt-4 text-blue-400 text-sm font-medium inline-flex items-center gap-1 md:opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    Read more →
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Bottom CTA -->
      <div class="mt-20 rounded-2xl border border-white/10 bg-gradient-to-br from-white/5 to-transparent p-10 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <h2 class="text-xl font-bold mb-1">Want to work together?</h2>
          <p class="text-gray-400 text-sm">I build fast, scalable web apps with Django and Next.js.</p>
        </div>
        <a
          href="/"
          class="shrink-0 inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-medium px-6 py-3 rounded-xl transition-colors text-sm"
        >
          View my portfolio
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

    </main>
  </body>
</Layout>
